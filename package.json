{
  "name": "react-light-table",
  "version": "3.1.2",
  "description": "A lightweight React data table with sorting, pagination, filtering, selection, virtualization, and theming",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run clean && npm run build:js && npm run build:css",
    "build:js": "tsup && mv dist/esm/index.d.mts dist/esm/index.d.ts",
    "build:css": "sass --no-source-map --style=compressed src/components/style.scss dist/style.css",
    "clean": "rm -rf ./dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:playground": "npm install --prefix playground && npm run dev --prefix playground",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matinkaviani/react-light-table"
  },
  "keywords": [
    "react",
    "react-component",
    "table",
    "data-table",
    "sortable",
    "pagination",
    "filtering",
    "virtual-scroll",
    "virtualization",
    "selection",
    "editable",
    "tree-table",
    "custom-table",
    "react-table",
    "headless",
    "ui",
    "component",
    "typescript"
  ],
  "author": "Matin Kaviani <matinkaviiani@gmail.com> (https://matinkaviani.net/)",
  "bugs": {
    "url": "https://github.com/matinkaviani/react-light-table/issues"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.85.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  },
  "files": [
    "/dist"
  ],
  "homepage": "https://github.com/matinkaviani/react-light-table#readme"
}
